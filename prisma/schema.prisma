generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum LeadStatus {
  new_lead
  enriching
  verifying
  verification_failed
  needs_review
  waiting_concierge
  draft_created
  exclude
  outreach_sent
  interested
  not_interested
  follow_up_queued
  follow_up_sent
  rejected
  suppressed
}

enum Tier {
  Tier1
  Tier2
  Exclude
}

enum DiscoverySource {
  google_maps
  google_places
  companies_house
  linkedin
  job_board
  manual
  import
}

enum SuppressionReason {
  replied
  bounced
  manual
}

enum FollowUpStatus {
  pending
  approved
  rejected
}

model Lead {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  status         LeadStatus @default(new_lead)
  enrichmentLock Boolean    @default(false)

  discoverySource DiscoverySource @default(manual)
  discoveryQuery  String?
  discoveryRunId  String?         @db.Uuid
  googlePlaceId   String?         @unique

  businessName   String
  normalizedName String?
  websiteDomain  String?
  city           String?
  country        String?
  address        String?
  googleRating   Float?
  websiteUrl     String?

  // ── Companies House identity ──
  companiesHouseNumber String?   @unique
  sicCodes             String[]
  accountsCategory     String?
  incorporatedOn       DateTime?
  companyStatus        String?

  // ── Stronger dedup signals ──
  phoneE164             String?
  outwardPostcode       String?
  geminiResearchJson    Json?
  ownerName             String?
  website               String?
  email                 String?
  phone                 String?
  linkedin              String?
  instagram             String?
  sector                String?
  employeeCountEstimate String?
  techStackSignals      String[]
  operationalSignals    String[]
  businessDescription   String?  @db.Text
  searchConfidence      Int?

  emailVerified     Boolean   @default(false)
  emailVerifiedAt   DateTime?
  mxValid           Boolean?
  smtpValid         Boolean?
  isCatchAll        Boolean?
  verificationScore Int?

  brandFitScore         Int?
  brandFitRationale     String? @db.Text
  primaryPainHypothesis String? @db.Text
  suggestedLane         String?
  tier                  Tier?
  draftSubject          String?
  draftBodyHtml         String? @db.Text
  outlookDraftId        String?

  draftCreatedAt  DateTime?
  lastContactedAt DateTime?
  sentBy          String?
  replyReceived   Boolean   @default(false)
  replyBody       String?   @db.Text
  replySentiment  String?
  replyReasoning  String?   @db.Text
  lastReplyAt     DateTime?

  followUpDraftId  String?
  followUpQueuedAt DateTime?

  teamsCardActivityId String?

  conversationId String? @db.Text

  notes String? @db.Text

  suppressions  Suppression[]
  followUpQueue FollowUpQueue[]

  @@index([status, discoverySource])
  @@index([status, enrichmentLock])
  @@index([email])
  @@index([status, lastContactedAt])
  @@index([businessName, city])
  @@index([normalizedName])
  @@index([websiteDomain])
  @@index([conversationId])
  @@index([phoneE164])
  @@index([outwardPostcode])
}

model Suppression {
  id        String            @id @default(uuid()) @db.Uuid
  createdAt DateTime          @default(now())
  email     String            @unique
  reason    SuppressionReason
  leadId    String?           @db.Uuid
  lead      Lead?             @relation(fields: [leadId], references: [id])

  @@index([email])
}

model FollowUpQueue {
  id       String   @id @default(uuid()) @db.Uuid
  queuedAt DateTime @default(now())

  leadId String @db.Uuid
  lead   Lead   @relation(fields: [leadId], references: [id])

  businessName    String
  email           String
  draftId         String?
  draftPreview    String? @db.Text
  geminiReasoning String  @db.Text

  status     FollowUpStatus @default(pending)
  approvedBy String?
  approvedAt DateTime?

  @@index([status])
  @@index([leadId])
}

model ErrorLog {
  id        String   @id @default(uuid()) @db.Uuid
  timestamp DateTime @default(now())

  scenarioName    String
  moduleName      String?
  errorCode       String
  errorMessage    String  @db.Text
  leadId          String? @db.Uuid
  killSwitchFired Boolean @default(false)

  @@index([errorCode, timestamp])
  @@index([timestamp])
}

model DiscoveryRun {
  id    String   @id @default(uuid()) @db.Uuid
  ranAt DateTime @default(now())

  source        DiscoverySource
  query         String
  region        String?
  leadsFound    Int             @default(0)
  totalResults  Int?
  nextPageToken String?
  durationMs    Int?

  @@index([source, ranAt])
  @@index([query, region])
}

model BotConversationRef {
  id                    String   @id @default(uuid()) @db.Uuid
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  channelType           String   @unique
  conversationReference Json
}

model RuntimeConfig {
  key         String   @id
  value       String
  valueType   String   @default("string")
  description String?
  updatedBy   String?
  updatedAt   DateTime @default(now()) @updatedAt

  @@index([updatedAt])
}

model ScrapeCache {
  domain       String   @id
  payload      Json
  fetchedAt    DateTime @default(now())
  expiresAt    DateTime
  pagesScraped Int      @default(0)
  confidence   String?

  @@index([expiresAt])
}

model CompaniesHouseCache {
  companyNumber String   @id
  payload       Json
  fetchedAt     DateTime @default(now())
  expiresAt     DateTime

  @@index([expiresAt])
}

model GraphSubscription {
  id                 String    @id @default(uuid()) @db.Uuid
  createdAt          DateTime  @default(now())
  subscriptionId     String    @unique
  resource           String
  changeType         String
  expirationDateTime DateTime
  renewedAt          DateTime?

  @@index([expirationDateTime])
}
