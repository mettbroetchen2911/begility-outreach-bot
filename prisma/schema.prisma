generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum LeadStatus {
  new_lead
  enriching
  verifying
  verification_failed
  needs_review
  waiting_concierge
  draft_created
  exclude
  outreach_sent
  interested
  not_interested
  follow_up_queued
  follow_up_sent
  rejected
  suppressed
}

enum Tier {
  Tier1
  Tier2
  Exclude
}

enum DiscoverySource {
  google_maps
  google_places
  companies_house
  linkedin
  job_board
  manual
  import
}

enum SuppressionReason {
  replied
  bounced
  manual
}

enum FollowUpStatus {
  pending
  approved
  rejected
}

model Lead {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  status             LeadStatus @default(new_lead)
  enrichmentLock     Boolean    @default(false)
  /**
   * When the row was locked for enrichment. Used to expire stale locks
   * left behind by crashed / killed orchestrator runs.
   */
  enrichmentLockedAt DateTime?

  discoverySource DiscoverySource @default(manual)
  discoveryQuery  String?
  discoveryRunId  String?         @db.Uuid
  googlePlaceId   String?         @unique

  businessName   String
  normalizedName String?
  websiteDomain  String?
  city           String?
  country        String?
  address        String?
  googleRating   Float?
  websiteUrl     String?

  // ── Companies House identity ──
  companiesHouseNumber String?   @unique
  sicCodes             String[]
  accountsCategory     String?
  incorporatedOn       DateTime?
  companyStatus        String?

  // ── Companies House richer signals ──
  accountsLastMadeUpTo        DateTime?
  accountsNextDue             DateTime?
  confirmationNextDue         DateTime?
  directorCount               Int?
  /**
   * Earliest officer appointment date — proxy for "founder still in" /
   * stable leadership.
   */
  earliestDirectorAppointedOn DateTime?
  /**
   * Most recent officer appointment date — flag for "new MD" outreach.
   */
  latestDirectorAppointedOn   DateTime?
  activeChargesCount          Int?
  recentChargeCreatedOn       DateTime?
  registeredOfficeMovedOn     DateTime?
  pscCount                    Int?

  // ── HMRC / VAT ──
  vatNumber        String?
  vatRegistered    Boolean?
  vatEffectiveFrom DateTime?
  vatCheckedAt     DateTime?

  // ── Latest filed financials (parsed from iXBRL) ──
  latestTurnover         BigInt?
  latestEmployeeCount    Int?
  priorYearTurnover      BigInt?
  priorYearEmployeeCount Int?
  turnoverGrowthPct      Float?
  employeeGrowthPct      Float?
  latestAccountsMadeUpTo DateTime?
  latestProfitLoss       BigInt?

  // ── CH composite pre-score (cheap, computed before scrape/Gemini) ──
  chPreScore Int?
  chSignals  String[]

  // ── Rendered authoritative facts block — what the scorer + drafter read.
  // Persisted so operators can audit what the model was actually told, and
  // so the Teams approval card can display it without recomputing.
  companyFactsBlock String? @db.Text

  // ── Tier-5 noise / risk audit columns ──
  // Last filed accounts type (e.g. "DORMANT", "AA02", "MICRO_ENTITY"). Used
  // to detect dormant filers that pass the accounts-category gate but
  // wouldn't actually buy operational change.
  lastAccountsType String?
  // True when the registered office matches a known nominee / formation-agent
  // address. Such companies are pass-through registrations, not real trading
  // premises — almost never our ICP.
  nomineeAddress Boolean? @default(false)
  // If we detected this company is a subsidiary of another lead in our DB
  // (same registered office + ≥1 director overlap), point at the parent so
  // the operator can decide whether to pitch the parent instead.
  subsidiaryOfLeadId String? @db.Uuid
  // Active corporate-entity PSCs (parent companies, holding co's). When
  // dominant, the decision-maker isn't reachable on the first call.
  corporatePscCount Int?
  // Number of "change of name" filings in the last 5 years — high counts
  // are a red flag for shell-company patterns and rebrand churn.
  recentNameChangeCount Int?

  // ── Send-window scheduling ──
  // When this lead is allowed to be processed by the orchestrator. If null,
  // processed immediately. If set in the future, the orchestrator skips it
  // until the window opens. Computed by send-window-scheduler from year-end
  // timing, accounts-due timing, anniversaries, and new-director events.
  nextOutreachWindow       DateTime?
  // Why we picked the window — surfaced in approval cards and used by drafter.
  nextOutreachWindowReason String?

  // ── Stronger dedup signals ──
  phoneE164             String?
  outwardPostcode       String?
  geminiResearchJson    Json?
  ownerName             String?
  website               String?
  email                 String?
  phone                 String?
  linkedin              String?
  instagram             String?
  sector                String?
  employeeCountEstimate String?
  techStackSignals      String[]
  operationalSignals    String[]
  businessDescription   String?  @db.Text
  searchConfidence      Int?

  emailVerified     Boolean   @default(false)
  emailVerifiedAt   DateTime?
  mxValid           Boolean?
  smtpValid         Boolean?
  isCatchAll        Boolean?
  verificationScore Int?

  brandFitScore         Int?
  brandFitRationale     String? @db.Text
  primaryPainHypothesis String? @db.Text
  suggestedLane         String?
  tier                  Tier?
  draftSubject          String?
  draftBodyHtml         String? @db.Text
  outlookDraftId        String?

  draftCreatedAt  DateTime?
  lastContactedAt DateTime?
  sentBy          String?
  replyReceived   Boolean   @default(false)
  replyBody       String?   @db.Text
  replySentiment  String?
  replyReasoning  String?   @db.Text
  lastReplyAt     DateTime?

  followUpDraftId  String?
  followUpQueuedAt DateTime?

  teamsCardActivityId String?

  conversationId String? @db.Text

  notes String? @db.Text

  suppressions  Suppression[]
  followUpQueue FollowUpQueue[]
  officers      Officer[]

  @@index([status, discoverySource])
  @@index([status, enrichmentLock])
  @@index([email])
  @@index([status, lastContactedAt])
  @@index([businessName, city])
  @@index([normalizedName])
  @@index([websiteDomain])
  @@index([conversationId])
  @@index([phoneE164])
  @@index([outwardPostcode])
  @@index([status, nextOutreachWindow])
  @@index([chPreScore])
}

model Suppression {
  id        String            @id @default(uuid()) @db.Uuid
  createdAt DateTime          @default(now())
  email     String            @unique
  reason    SuppressionReason
  leadId    String?           @db.Uuid
  lead      Lead?             @relation(fields: [leadId], references: [id])

  @@index([email])
}

model FollowUpQueue {
  id       String   @id @default(uuid()) @db.Uuid
  queuedAt DateTime @default(now())

  leadId String @db.Uuid
  lead   Lead   @relation(fields: [leadId], references: [id])

  businessName    String
  email           String
  draftId         String?
  draftPreview    String? @db.Text
  geminiReasoning String  @db.Text

  status     FollowUpStatus @default(pending)
  approvedBy String?
  approvedAt DateTime?

  @@index([status])
  @@index([leadId])
}

model ErrorLog {
  id        String   @id @default(uuid()) @db.Uuid
  timestamp DateTime @default(now())

  scenarioName    String
  moduleName      String?
  errorCode       String
  errorMessage    String  @db.Text
  leadId          String? @db.Uuid
  killSwitchFired Boolean @default(false)

  @@index([errorCode, timestamp])
  @@index([timestamp])
}

model DiscoveryRun {
  id    String   @id @default(uuid()) @db.Uuid
  ranAt DateTime @default(now())

  source        DiscoverySource
  query         String
  region        String?
  leadsFound    Int             @default(0)
  totalResults  Int?
  nextPageToken String?
  durationMs    Int?

  @@index([source, ranAt])
  @@index([query, region])
}

model BotConversationRef {
  id                    String   @id @default(uuid()) @db.Uuid
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  channelType           String   @unique
  conversationReference Json
}

model RuntimeConfig {
  key         String   @id
  value       String
  valueType   String   @default("string")
  description String?
  updatedBy   String?
  updatedAt   DateTime @default(now()) @updatedAt

  @@index([updatedAt])
}

model ScrapeCache {
  domain       String   @id
  payload      Json
  fetchedAt    DateTime @default(now())
  expiresAt    DateTime
  pagesScraped Int      @default(0)
  confidence   String?

  @@index([expiresAt])
}

model CompaniesHouseCache {
  companyNumber String   @id
  payload       Json
  fetchedAt     DateTime @default(now())
  expiresAt     DateTime

  @@index([expiresAt])
}

// ---------------------------------------------------------------------------
// Director / Officer graph
//
// Companies House identifies a natural person by (name + DOB month/year). It
// does not expose full DOB. We use the (name, dobMonth, dobYear) triple as
// the de-facto identity, which is what CH itself does internally.
//
// A Director may sit on many companies; a Lead may have many directors. The
// Officer junction carries appointment dates and role.
// ---------------------------------------------------------------------------

model Director {
  id                 String    @id @default(uuid()) @db.Uuid
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  /**
   * Lower-cased, whitespace-collapsed full name.
   */
  normalizedName     String
  fullName           String
  // 0 = unknown. Composite uniques cannot include nullable fields, and
  // Companies House anonymises full DOB anyway — only month/year are public.
  dobMonth           Int       @default(0)
  dobYear            Int       @default(0)
  nationality        String?
  occupation         String?
  countryOfResidence String?
  officers           Officer[]

  @@unique([normalizedName, dobMonth, dobYear])
  @@index([normalizedName])
}

model Officer {
  id          String    @id @default(uuid()) @db.Uuid
  createdAt   DateTime  @default(now())
  leadId      String    @db.Uuid
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  directorId  String    @db.Uuid
  director    Director  @relation(fields: [directorId], references: [id], onDelete: Cascade)
  role        String
  appointedOn DateTime?
  resignedOn  DateTime?
  /**
   * True if currently in office (no resignation date). Computed at upsert time
   * so we can index on it for "active directors of company X" queries.
   */
  isActive    Boolean   @default(true)

  @@unique([leadId, directorId, role])
  @@index([leadId, isActive])
  @@index([directorId, isActive])
}

// ---------------------------------------------------------------------------
// Latest filed financials parsed from iXBRL accounts. Mirrors the same data
// stored on the Lead row (for query convenience), but persisted here keyed by
// company number for re-use across re-discovery runs and historical tracking.
// ---------------------------------------------------------------------------

model CompanyFinancials {
  companyNumber      String    @id
  fetchedAt          DateTime  @default(now())
  madeUpTo           DateTime?
  turnover           BigInt?
  employeeCount      Int?
  profitLoss         BigInt?
  priorTurnover      BigInt?
  priorEmployeeCount Int?
  priorProfitLoss    BigInt?
  rawDocumentId      String?
  parseError         String?

  @@index([fetchedAt])
}

model GraphSubscription {
  id                 String    @id @default(uuid()) @db.Uuid
  createdAt          DateTime  @default(now())
  subscriptionId     String    @unique
  resource           String
  changeType         String
  expirationDateTime DateTime
  renewedAt          DateTime?

  @@index([expirationDateTime])
}
